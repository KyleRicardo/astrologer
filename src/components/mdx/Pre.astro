---
import { cn } from '@/lib/utils'
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'pre'>
const { class: className, ...props } = Astro.props
---

<pre
  class={cn(
    'not-prose no-scrollbar min-w-0 overflow-x-auto overflow-y-auto overscroll-x-contain overscroll-y-auto px-4 py-3.5 outline-none has-data-highlighted-line:px-0 has-data-line-numbers:px-0 has-data-[slot=tabs]:p-0',
    className,
  )}
  {...props}
><slot /></pre>
