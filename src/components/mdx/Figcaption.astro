---
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'figcaption'>
const { class: className, ...props } = Astro.props

const getIconNameForLanguageExtension = (extension: string) => {
  switch (extension) {
    case 'astro':
      return 'astro'
    case 'css':
      return 'css'
    case 'json':
      return 'json'
    case 'js':
    case 'javascript':
      return 'js'
    case 'ts':
    case 'typescript':
      return 'ts'
    case 'jsx':
    case 'tsx':
      return 'react'
    default:
      return 'file'
  }
}

const iconName =
  'data-language' in props && typeof props['data-language'] === 'string'
    ? getIconNameForLanguageExtension(props['data-language'])
    : null
---

<figcaption
  class={cn(
    'text-code-foreground [&_svg]:text-code-foreground flex items-center gap-2 [&_svg]:size-4 [&_svg]:opacity-70',
    className,
  )}
  {...props}
>
  {iconName && <Icon name={iconName} class="size-4" />}
  <slot />
</figcaption>
