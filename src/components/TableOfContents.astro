---
import { useTranslations, type Lang } from '@/i18n/utils'
import { buildTocTree } from '@/utils/toc'

interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>
  lang: Lang
}

const { headings, lang } = Astro.props
const tocTree = buildTocTree(headings)

const t = useTranslations(lang)

// Don't render if no headings
if (tocTree.length === 0) {
  return null
}
---

<nav
  id="toc"
  aria-label="Table of Contents"
  class="motion-safe:animate-fade-in-up motion-safe:delay-540 toc ml-auto hidden w-64 shrink-0 lg:block"
>
  <div class="toc-inner sticky top-30">
    <div class="text-foreground mb-3 text-sm font-semibold">
      {t('toc.title')}
    </div>
    <ul class="toc-list space-y-1">
      {tocTree.map((h2) => (
        <li>
          <a
            href={`#${h2.slug}`}
            class="toc-link text-muted-foreground hover:text-foreground block py-1 text-sm transition-colors duration-200"
            data-slug={h2.slug}
          >
            {h2.text}
          </a>
          {h2.children.length > 0 && (
            <ul class="space-y-1 pl-3">
              {h2.children.map((h3) => (
                <li>
                  <a
                    href={`#${h3.slug}`}
                    class="toc-link text-muted-foreground hover:text-foreground block py-1 text-sm transition-colors duration-200"
                    data-slug={h3.slug}
                  >
                    {h3.text}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
.toc-link.active {
  color: var(--primary);
  font-weight: 500;
}
</style>

<script>
function initToc() {
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
  if (tocLinks.length === 0) return

  const headingElements = Array.from(tocLinks)
    .map(link => document.getElementById(link.dataset.slug!))
    .filter((el): el is HTMLElement => el !== null)

  if (headingElements.length === 0) return

  function setActiveLink(slug: string) {
    tocLinks.forEach(link => {
      const isActive = link.dataset.slug === slug
      link.classList.toggle('active', isActive)
      if (isActive) {
        link.setAttribute('aria-current', 'true')
      } else {
        link.removeAttribute('aria-current')
      }
    })
  }

  // Guard: skip observer updates during programmatic scroll
  let scrollTarget: string | null = null

  function scrollTo(target: HTMLElement, slug: string) {
    scrollTarget = slug
    setActiveLink(slug)
    window.addEventListener(
      'scrollend',
      () => {
        scrollTarget = null
      },
      { once: true },
    )
    const reduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches
    target.scrollIntoView({
      behavior: reduced ? 'instant' : 'smooth',
      block: 'start',
    })
  }

  // IntersectionObserver: activate whichever heading enters the
  // top band of the viewport. When it exits, keep it active until
  // the next heading enters.
  const observer = new IntersectionObserver(
    (entries) => {
      if (scrollTarget) return

      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActiveLink(entry.target.id)
        }
      }
    },
    {
      // 80px header offset, observe only top 20% of viewport
      rootMargin: '-80px 0px -80% 0px',
      threshold: 0,
    },
  )

  headingElements.forEach(el => observer.observe(el))

  // Click handlers
  tocLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault()
      const slug = link.dataset.slug
      if (!slug) return

      const target = document.getElementById(slug)
      if (!target) return

      history.pushState(null, '', `#${slug}`)
      scrollTo(target, slug)
    })
  })

  // Hash navigation: sync active link (browser handles scroll)
  const hash = window.location.hash.slice(1)
  if (hash) {
    setActiveLink(hash)
  }

  // Cleanup for View Transitions
  document.addEventListener(
    'astro:before-swap',
    () => observer.disconnect(),
    { once: true },
  )
}

document.addEventListener('astro:page-load', initToc)
</script>
