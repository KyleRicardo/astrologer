---
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '@/i18n/utils'
import NavIcon from './NavIcon.astro'
import ModeToggle from './ModeToggle.astro'
import LangSwitcher from './LangSwitcher.astro'
import { Icon } from 'astro-icon/components'
import { getSiteConfig } from '@/site.config'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
const siteConfig = getSiteConfig(lang)

interface Props {
  showProgressBar?: boolean
}

const { showProgressBar = false } = Astro.props
---

<header class="bg-background/95 supports-backdrop-filter:bg-background/60 sticky top-0 z-50 w-full border-b border-dashed border-black/10 backdrop-blur dark:border-white/15">
  <div class="container mx-auto flex h-14 max-w-[1400px] items-center gap-2 px-4 md:gap-4">
    <button
      id="mobile-menu-trigger"
      type="button"
      class="group absolute top-0 left-0 z-3 flex h-14 w-14 items-center justify-center md:hidden"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label={t('nav.group.navigation')}
    >
      <span
        class="absolute h-px w-4 rounded-full bg-current transition-transform duration-200 ease-out -translate-y-[5px] group-aria-expanded:translate-y-0 group-aria-expanded:rotate-45"
      />
      <span
        class="absolute h-px w-4 rounded-full bg-current transition-transform duration-200 ease-out translate-y-[5px] group-aria-expanded:translate-y-0 group-aria-expanded:-rotate-45"
      />
    </button>
    <nav
      id="mobile-menu"
      aria-label={t('nav.group.navigation')}
      class="bg-background absolute top-14 left-0 z-2 h-[calc(100dvh-3.5rem)] w-full overflow-y-auto transition-[opacity,visibility] duration-200 ease-out data-[state=closed]:invisible data-[state=closed]:opacity-0 data-[state=open]:visible data-[state=open]:opacity-100 md:hidden"
      data-state="closed"
    >
      <div class="flex flex-col gap-8 px-8 pt-6">
        <div>
          <span class="text-muted-foreground text-sm">
            {t('nav.group.navigation')}
          </span>
          <ul class="flex flex-col gap-3 mt-5">
            <li>
              <a
                href={translatePath('/posts')}
                class="text-foreground text-2xl font-medium"
              >{t('nav.blog')}</a>
            </li>
            {siteConfig.enableProjectsShowcase && (
              <li>
                <a
                  href={translatePath('/projects')}
                  class="text-foreground text-2xl font-medium"
                >{t('nav.projects')}</a>
              </li>
            )}
            {siteConfig.enableAboutMe && (
              <li>
                <a
                  href={translatePath('/about')}
                  class="text-foreground text-2xl font-medium"
                >{t('nav.about')}</a>
              </li>
            )}
          </ul>
        </div>
        <div>
          <span class="text-muted-foreground mb-[20px] text-sm">
            {t('nav.group.connect')}
          </span>
          <ul class="flex flex-col gap-3">
            {siteConfig.socials.map(social => (
              <li>
                <a
                  href={social.url}
                  class="text-foreground text-2xl font-medium"
                  target={social.url.startsWith('mailto:')
                  ? undefined
                  : '_blank'}
                  rel={social.url.startsWith('mailto:')
                  ? undefined
                  : 'noopener noreferrer'}
                >{social.name}</a>
              </li>
            ))}
            <li>
              <a
                href={translatePath('/rss.xml')}
                class="text-foreground text-2xl font-medium"
                target="_blank"
                rel="noopener noreferrer"
              >RSS Feed</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
    <div class="mr-4 flex">
      <a
        class="mr-4 flex items-center gap-2 lg:mr-6"
        href={translatePath('/')}
      >
        <span class="ml-8 inline-block font-bold md:ml-0">
          {siteConfig.title}
        </span>
      </a>
      <nav
        class="hidden items-center gap-4 text-sm md:flex lg:gap-6"
        aria-label={t('nav.group.navigation')}
      >
        <a
          class="hover:text-foreground/80 text-foreground/80 transition-colors"
          href={translatePath('/posts')}
        >{t('nav.blog')}</a>
        {siteConfig.enableProjectsShowcase && (
          <a
            class="hover:text-foreground/80 text-foreground/80 transition-colors"
            href={translatePath('/projects')}
          >{t('nav.projects')}</a>
        )}
        {siteConfig.enableAboutMe && (
          <a
            class="hover:text-foreground/80 text-foreground/80 transition-colors"
            href={translatePath('/about')}
          >{t('nav.about')}</a>
        )}
      </nav>
    </div>
    <div class="ml-auto flex items-center md:flex-1 md:justify-end">
      <div class="hidden w-full flex-1 md:flex md:w-auto md:flex-none">
        <button
          data-search-trigger
          aria-label={t('search.trigger')}
          class="focus-visible:ring-ring border-input hover:bg-accent hover:text-accent-foreground bg-muted/50 text-muted-foreground relative inline-flex h-8 w-full items-center justify-start gap-2 rounded-[0.5rem] border px-4 py-2 text-sm font-normal whitespace-nowrap shadow-none transition-colors focus-visible:ring-1 focus-visible:outline-none disabled:pointer-events-none disabled:opacity-50 sm:pr-12 md:w-40 lg:w-56 xl:w-64 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0"
        >
          <span class="hidden lg:inline-flex">Search...</span>
          <kbd
            class="bg-muted pointer-events-none absolute top-[0.3rem] right-[0.3rem] hidden h-5 items-center gap-1 rounded border px-1.5 font-mono text-[10px] font-medium opacity-100 select-none sm:flex"
          >
            <span class="text-xs">⌘</span>K
          </kbd>
        </button>
      </div>
      <nav
        aria-label={t('a11y.socialLinks')}
        class="ml-2 hidden md:inline-block"
      >
        <ul class="flex items-center gap-1">
          {siteConfig.socials.filter(social => social.showOnHeader).map(
            social => (
              <li>
                <NavIcon
                  name={social.name}
                  href={social.url}
                  icon={social.icon}
                  external={true}
                />
              </li>
            ),
          )}
          <li>
            <NavIcon
              name="RSS Feed"
              href={translatePath('/rss.xml')}
              icon="ri:rss-fill"
              external={true}
            />
          </li>
        </ul>
      </nav>
      <div class="ml-1 flex items-center">
        <button
          data-search-trigger
          class="
            inline-flex size-10 items-center justify-center
            rounded-md transition-colors
            hover:bg-accent hover:text-accent-foreground
            md:hidden
          "
          aria-label={t('search.trigger')}
        >
          <Icon name="ri:search-line" class="size-4" />
        </button>
        <LangSwitcher />
        <ModeToggle />
      </div>
    </div>
  </div>
  {showProgressBar && (
    <div
      id="reading-progress"
      class="bg-primary absolute -bottom-px left-0 z-10 h-0.5 w-full origin-left transition-transform duration-100 ease-out will-change-transform"
      style="transform: scaleX(0)"
    >
    </div>
  )}
</header>

<script>
function initMobileMenu() {
  const _trigger = document.getElementById('mobile-menu-trigger')
  const _menu = document.getElementById('mobile-menu')
  if (!_trigger || !_menu) return
  const trigger = _trigger
  const menu = _menu

  const isOpen = () => menu.getAttribute('data-state') === 'open'

  // Collect header siblings for inert management
  const header = trigger.closest('header')
  const siblings: Element[] = []
  if (header?.parentElement) {
    for (const child of header.parentElement.children) {
      if (child !== header) siblings.push(child)
    }
  }

  function openMenu() {
    menu.setAttribute('data-state', 'open')
    trigger.setAttribute('aria-expanded', 'true')
    document.documentElement.style.overflow = 'hidden'
    siblings.forEach(el => el.setAttribute('inert', ''))
    document.getElementById('reading-progress')
      ?.style.setProperty('opacity', '0')
  }

  function closeMenu() {
    menu.setAttribute('data-state', 'closed')
    trigger.setAttribute('aria-expanded', 'false')
    document.documentElement.style.overflow = ''
    siblings.forEach(el => el.removeAttribute('inert'))
    document.getElementById('reading-progress')
      ?.style.removeProperty('opacity')
  }

  function toggleMenu() {
    if (isOpen()) {
      closeMenu()
      trigger.focus()
    } else {
      openMenu()
    }
  }

  function handleKeyDown(e: KeyboardEvent) {
    if (e.key === 'Escape' && isOpen()) {
      closeMenu()
      trigger.focus()
    }
  }

  // Close menu when crossing the md breakpoint
  const md = window.matchMedia('(min-width: 768px)')
  function handleBreakpoint() {
    if (md.matches && isOpen()) {
      const focusInMenu = menu.contains(document.activeElement)
      closeMenu()
      if (focusInMenu) {
        header?.querySelector<HTMLElement>('a')?.focus()
      }
    }
  }

  // Close menu when clicking a link inside it
  function handleMenuClick(e: Event) {
    if ((e.target as HTMLElement).closest('a')) closeMenu()
  }

  trigger.addEventListener('click', toggleMenu)
  document.addEventListener('keydown', handleKeyDown)
  md.addEventListener('change', handleBreakpoint)
  menu.addEventListener('click', handleMenuClick)

  // Cleanup for View Transitions
  document.addEventListener('astro:before-swap', () => {
    trigger.removeEventListener('click', toggleMenu)
    document.removeEventListener('keydown', handleKeyDown)
    md.removeEventListener('change', handleBreakpoint)
    menu.removeEventListener('click', handleMenuClick)
    if (isOpen()) {
      document.documentElement.style.overflow = ''
      siblings.forEach(el => el.removeAttribute('inert'))
    }
  }, { once: true })
}

function initProgressBar() {
  const _progressBar = document.getElementById('reading-progress')
  if (!_progressBar) return
  const progressBar = _progressBar

  let ticking = false
  let docHeight = document.documentElement.scrollHeight
    - window.innerHeight

  function updateProgress() {
    const scrollPercent = docHeight > 0
      ? Math.min(Math.max(window.scrollY / docHeight, 0), 1)
      : 0
    progressBar.style.transform = `scaleX(${scrollPercent})`
    ticking = false
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(updateProgress)
      ticking = true
    }
  }

  function onResize() {
    docHeight = document.documentElement.scrollHeight
      - window.innerHeight
  }

  updateProgress()
  window.addEventListener('scroll', onScroll, { passive: true })
  window.addEventListener('resize', onResize, { passive: true })

  document.addEventListener('astro:before-swap', () => {
    window.removeEventListener('scroll', onScroll)
    window.removeEventListener('resize', onResize)
  }, { once: true })
}

document.addEventListener('astro:page-load', () => {
  initMobileMenu()
  initProgressBar()
})
</script>
