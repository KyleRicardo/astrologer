---
import { cn } from '@/lib/utils'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
  class?: string
}

const { items, class: className } = Astro.props
---

<nav aria-label="breadcrumb" class={cn(className)}>
  <ol class="text-muted-foreground flex flex-wrap items-center gap-1.5 text-sm wrap-break-word sm:gap-2.5">
    {items.map((item, i) => (
      <>
        <li class="inline-flex items-center gap-1.5">
          {item.href ? (
            <a href={item.href} class="hover:text-foreground transition-colors">
              {item.label}
            </a>
          ) : (
             <span class="text-foreground font-normal" aria-current="page">
               {item.label}
             </span>
           )}
        </li>
        {i < items.length - 1 && (
          <li role="presentation" aria-hidden="true" class="[&>svg]:size-3.5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </li>
        )}
      </>
    ))}
  </ol>
</nav>
