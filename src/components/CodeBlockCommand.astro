---
import { Icon } from 'astro-icon/components'
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'pre'> {
  __npm__?: string
  __yarn__?: string
  __pnpm__?: string
  __bun__?: string
}
const { __npm__, __yarn__, __pnpm__, __bun__ } = Astro.props

const tabs = {
  pnpm: __pnpm__,
  npm: __npm__,
  yarn: __yarn__,
  bun: __bun__,
}

const uid = Math.random().toString(36).substring(2, 9)
---

<code-block-command
  class="overflow-x-auto"
><div
    dir="ltr"
    data-slot="tabs"
    data-orientation="horizontal"
    class="group/tabs flex items-center gap-2 border-b border-border/50 px-3 py-1"
  >
    <div class="flex size-4 items-center justify-center rounded-[1px] bg-foreground opacity-70">
      <Icon name="ri:terminal-line" class="size-3 text-code" />
    </div>
    <div
      role="tablist"
      aria-label="Package Manager"
      class="group-data-[orientation=horizontal]/tabs:h-9 data-[variant=line]:rounded-none group/tabs-list text-muted-foreground inline-flex w-fit items-center justify-center group-data-[orientation=vertical]/tabs:h-fit group-data-[orientation=vertical]/tabs:flex-col rounded-none bg-transparent p-0"
    >
      {Object.entries(tabs).map(([key]) => (
        <button
          role="tab"
          id={`tab-${uid}-${key}`}
          data-slot="tabs-trigger"
          aria-controls={`panel-${uid}-${key}`}
          data-pkg-target={key}
          class="pkg-tab-btn focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring text-foreground/60 hover:text-foreground dark:text-muted-foreground dark:hover:text-foreground relative inline-flex flex-1 items-center justify-center gap-1.5 rounded-md px-2 py-1 text-sm font-medium whitespace-nowrap transition-all group-data-[orientation=vertical]/tabs:w-full group-data-[orientation=vertical]/tabs:justify-start focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 group-data-[variant=default]/tabs-list:data-[state=active]:shadow-sm group-data-[variant=line]/tabs-list:data-[state=active]:shadow-none [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 group-data-[variant=line]/tabs-list:bg-transparent group-data-[variant=line]/tabs-list:data-[state=active]:bg-transparent dark:group-data-[variant=line]/tabs-list:data-[state=active]:border-transparent dark:group-data-[variant=line]/tabs-list:data-[state=active]:bg-transparent data-[state=active]:bg-background dark:data-[state=active]:text-foreground dark:data-[state=active]:border-input dark:data-[state=active]:bg-input/30 data-[state=active]:text-foreground after:bg-foreground after:absolute after:opacity-0 after:transition-opacity group-data-[orientation=horizontal]/tabs:after:inset-x-0 group-data-[orientation=horizontal]/tabs:after:bottom-[-5px] group-data-[orientation=horizontal]/tabs:after:h-0.5 group-data-[orientation=vertical]/tabs:after:inset-y-0 group-data-[orientation=vertical]/tabs:after:-right-1 group-data-[orientation=vertical]/tabs:after:w-0.5 group-data-[variant=line]/tabs-list:data-[state=active]:after:opacity-100 data-[state=active]:border-input h-7 border border-transparent pt-0.5 shadow-none!"
          aria-selected="false"
          tabindex="-1"
        >
          {key}
        </button>
      ))}
    </div>
  </div><div class="no-scrollbar overflow-x-auto">{Object.entries(tabs).map(([key, value]) => (<div
        role="tabpanel"
        id={`panel-${uid}-${key}`}
        aria-labelledby={`tab-${uid}-${key}`}
        data-pkg-panel={key}
        class="pkg-tab-panel mt-0 px-4 py-3.5"
        tabindex="0"
      ><pre><code
            class="relative font-mono text-sm leading-none"
            data-language="bash"
          >{value}</code></pre></div>))}</div><button
          id="copy-button"
          data-slot="copy-button"
    aria-label="Copy code"
    class="inline-flex items-center justify-center gap-2 absolute top-2 right-2 whitespace-nowrap rounded-md text-sm font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50 bg-code z-10 size-7 hover:opacity-100 focus-visible:opacity-100"
  ><svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-3 w-3 copy-icon transition-all"
    >
      <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
      <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
    </svg><svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-3 w-3 check-icon absolute scale-0 opacity-0 transition-all"
    >
      <polyline points="20 6 9 17 4 12" />
    </svg></button></code-block-command><style is:global>
.pkg-tab-panel {
  display: none;
}

html[data-pkg="npm"] .pkg-tab-panel[data-pkg-panel="npm"],
html[data-pkg="pnpm"] .pkg-tab-panel[data-pkg-panel="pnpm"],
html[data-pkg="yarn"] .pkg-tab-panel[data-pkg-panel="yarn"],
html[data-pkg="bun"] .pkg-tab-panel[data-pkg-panel="bun"] {
  display: block;
}

html[data-pkg="npm"] .pkg-tab-btn[data-pkg-target="npm"],
html[data-pkg="pnpm"] .pkg-tab-btn[data-pkg-target="pnpm"],
html[data-pkg="yarn"] .pkg-tab-btn[data-pkg-target="yarn"],
html[data-pkg="bun"] .pkg-tab-btn[data-pkg-target="bun"] {
  color: var(--foreground);
}
</style><script>
class CodeBlockCommand extends HTMLElement {
  #buttons: NodeListOf<HTMLButtonElement> | null = null
  #tablist: HTMLElement | null = null
  #copyButton: HTMLElement | null = null
  #copyIcon: Element | null = null
  #checkIcon: Element | null = null
  #copyTimeout: ReturnType<typeof setTimeout> | undefined
  #handleSync: ((e: Event) => void) | null = null
  #handleKeydown: ((e: KeyboardEvent) => void) | null = null
  #handleCopy: (() => void) | null = null
  #buttonClickHandlers: Map<Element, () => void> = new Map()

  connectedCallback() {
    this.#buttons = this.querySelectorAll<HTMLButtonElement>('[role="tab"]')
    this.#tablist = this.querySelector('[role="tablist"]')
    this.#copyButton = this.querySelector('[data-slot="copy-button"]')
    this.#copyIcon = this.querySelector('.copy-icon')
    this.#checkIcon = this.querySelector('.check-icon')

    const currentPkg = document.documentElement.getAttribute('data-pkg')
      || 'pnpm'
    this.#updateA11y(currentPkg)

    this.#buttons.forEach((btn) => {
      const handler = () => {
        const pkg = btn.getAttribute('data-pkg-target')
        if (pkg) {
          localStorage.setItem('preferred-pkg', pkg)
          document.documentElement.setAttribute('data-pkg', pkg)
          window.dispatchEvent(
            new CustomEvent('pkg-synced', { detail: pkg }),
          )
          btn.focus()
        }
      }
      this.#buttonClickHandlers.set(btn, handler)
      btn.addEventListener('click', handler)
    })

    this.#handleKeydown = (e: KeyboardEvent) => {
      if (!this.#buttons) return
      const tabs = Array.from(this.#buttons)
      const current = tabs.indexOf(
        document.activeElement as HTMLButtonElement,
      )
      if (current === -1) return

      let next: number | null = null
      switch (e.key) {
        case 'ArrowRight':
          next = (current + 1) % tabs.length
          break
        case 'ArrowLeft':
          next = (current - 1 + tabs.length) % tabs.length
          break
        case 'Home':
          next = 0
          break
        case 'End':
          next = tabs.length - 1
          break
        default:
          return
      }
      e.preventDefault()
      tabs[next].click()
    }
    this.#tablist?.addEventListener('keydown', this.#handleKeydown)

    this.#handleCopy = async () => {
      if (!this.#copyIcon || !this.#checkIcon) return

      const currentPkg = document.documentElement.getAttribute('data-pkg')
        || 'pnpm'
      const panel = this.querySelector(
        `.pkg-tab-panel[data-pkg-panel="${currentPkg}"]`,
      )
      const codeToCopy = panel?.querySelector('code')?.textContent
      if (!codeToCopy) return

      try {
        await navigator.clipboard.writeText(codeToCopy)

        this.#copyIcon.classList.remove('scale-100', 'opacity-100')
        this.#copyIcon.classList.add('scale-0', 'opacity-0')
        this.#checkIcon.classList.remove('scale-0', 'opacity-0')
        this.#checkIcon.classList.add('scale-100', 'opacity-100')

        clearTimeout(this.#copyTimeout)
        this.#copyTimeout = setTimeout(() => {
          this.#copyIcon?.classList.remove('scale-0', 'opacity-0')
          this.#copyIcon?.classList.add('scale-100', 'opacity-100')
          this.#checkIcon?.classList.remove('scale-100', 'opacity-100')
          this.#checkIcon?.classList.add('scale-0', 'opacity-0')
        }, 2000)
      } catch (err) {
        console.error('Failed to copy text: ', err)
      }
    }
    this.#copyButton?.addEventListener('click', this.#handleCopy)

    this.#handleSync = (e: Event) => {
      this.#updateA11y((e as CustomEvent).detail)
    }
    window.addEventListener('pkg-synced', this.#handleSync)
  }

  disconnectedCallback() {
    this.#buttonClickHandlers.forEach((handler, btn) => {
      btn.removeEventListener('click', handler)
    })
    this.#buttonClickHandlers.clear()

    if (this.#handleKeydown) {
      this.#tablist?.removeEventListener('keydown', this.#handleKeydown)
    }
    if (this.#handleCopy) {
      this.#copyButton?.removeEventListener('click', this.#handleCopy)
    }
    if (this.#handleSync) {
      window.removeEventListener('pkg-synced', this.#handleSync)
    }
    clearTimeout(this.#copyTimeout)
  }

  #updateA11y(pkg: string) {
    this.#buttons?.forEach((btn) => {
      const isSelected = btn.getAttribute('data-pkg-target') === pkg
      btn.setAttribute('aria-selected', isSelected ? 'true' : 'false')
      btn.setAttribute('tabindex', isSelected ? '0' : '-1')
      btn.setAttribute('data-state', isSelected ? 'active' : 'inactive')
    })
  }
}

if (!customElements.get('code-block-command')) {
  customElements.define('code-block-command', CodeBlockCommand)
}
</script>
