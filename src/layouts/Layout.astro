---
import { ClientRouter } from 'astro:transitions'

import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import SearchDialog from '@/components/SearchDialog.astro'
import '@/styles/global.css'
import '@/styles/fonts'
import 'medium-zoom/dist/style.css'

import { getLangFromUrl, getLocaleFromLang, type Lang } from '@/i18n/utils'
import { getSiteConfig } from '@/site.config'
import { useTranslations } from '@/i18n/utils'

interface Props {
  title: string
  description?: string
  image?: string
  ogType?: 'website' | 'article'
  showProgressBar?: boolean
  lang?: Lang
  hideChrome?: boolean
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site)

const {
  title,
  description: _description,
  image,
  ogType = 'website',
  showProgressBar = false,
  lang: propLang,
  hideChrome = false,
} = Astro.props

const lang = propLang ?? getLangFromUrl(Astro.url)

const site = Astro.site?.toString() ?? ''

const locale = getLocaleFromLang(lang)

const siteConfig = getSiteConfig(lang)
const t = useTranslations(lang)

const description = _description ?? siteConfig.description

const ogImage = image
  ? new URL(image, site).href
  : new URL('/og-default.png', site).href
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- KaTeX: non-render-blocking async load (only math pages need it) -->
    <link
      href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
      rel="stylesheet"
      media="print"
      onload="this.setAttribute('media', 'all')"
    >
    <noscript>
      <link
        href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
        rel="stylesheet"
      >
    </noscript>
    <script is:inline>
    function setPkgPreference(doc) {
      const savedPkg = localStorage.getItem('preferred-pkg') || 'pnpm'
      doc.documentElement.setAttribute('data-pkg', savedPkg)
    }

    setPkgPreference(document)

    window.addEventListener('storage', function(e) {
      if (e.key === 'preferred-pkg' && e.newValue) {
        document.documentElement.setAttribute('data-pkg', e.newValue)
        window.dispatchEvent(
          new CustomEvent('pkg-synced', { detail: e.newValue }),
        )
      }
    })

    document.addEventListener('astro:before-swap', function(event) {
      setPkgPreference(event.newDocument)
    })
    </script>
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteConfig.title}
      href={new URL('rss.xml', Astro.site)}
    />
    <title>{`${title}${siteConfig.titleSeparator}${siteConfig.title}`}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
  </head>
  <body class="min-h-dvh bg-background antialiased">
    <a
      href="#main-content"
      class="bg-primary text-primary-foreground sr-only fixed top-4 left-4 z-[100] rounded-md px-4 py-2 text-sm font-medium focus:not-sr-only"
    >
      {t('a11y.skipToContent')}
    </a>
    <div class="relative flex min-h-dvh flex-col bg-background">
      {!hideChrome && <Header showProgressBar={showProgressBar} />}
      <div id="main-content"></div>
      <slot />
      {!hideChrome && <Footer lang={lang} />}
    </div>
    {!hideChrome && <SearchDialog />}
  </body>
</html>

<style>
html,
body {
  margin: 0;
  width: 100%;
  height: 100%;
  scrollbar-gutter: stable;
}
</style>

<script is:inline>
// Theme preference logic is duplicated from src/utils/theme.ts because
// is:inline scripts cannot import ES modules. Keep both in sync.
function setDarkMode(document) {
  const getThemePreference = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme')
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches
      ? 'dark'
      : 'light'
  }
  const isDark = getThemePreference() === 'dark'
  document.documentElement.classList[isDark ? 'add' : 'remove']('dark')

  if (typeof localStorage !== 'undefined') {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains('dark')
      localStorage.setItem('theme', isDark ? 'dark' : 'light')
    })
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    })
  }
}

setDarkMode(document)

document.addEventListener('astro:before-swap', (event) => {
  // Pass the incoming document to set the theme on it
  setDarkMode(event.newDocument)
})
</script>
