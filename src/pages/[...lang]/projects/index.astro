---
import ProjectCard from '@/components/ProjectCard.astro'
import { useTranslations, type Lang } from '@/i18n/utils'
import Layout from '@/layouts/Layout.astro'
import ProjectLayout from '@/layouts/ProjectLayout.astro'
import { getProjectsByLang } from '@/utils/get-contents'
import { languages, defaultLang } from '@/i18n/ui'

export function getStaticPaths() {
  return Object.keys(languages).map((l) => ({
    params: { lang: l === defaultLang ? undefined : l },
    props: { lang: l as Lang },
  }))
}

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)
const sortedProjects = await getProjectsByLang(lang)
---

<Layout title={t('nav.projects')}>
  <ProjectLayout>
    <section
      aria-label="projects"
      class="container mx-auto grid gap-8 px-4 md:grid-cols-2 xl:grid-cols-3"
    >
      {sortedProjects.map((project) => (
        <div><ProjectCard project={project} /></div>
      ))}
    </section>
  </ProjectLayout>
</Layout>
