---
import ProjectDetail from '@/components/ProjectDetail.astro'
import { getProjectPaths } from '@/utils/get-contents'
import { languages, defaultLang } from '@/i18n/ui'
import type { Lang } from '@/i18n/utils'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const langs = Object.keys(languages) as Lang[]
  const paths = await Promise.all(
    langs.map(async (lang) => {
      const projectPaths = await getProjectPaths(lang)
      return projectPaths.map((path) => ({
        params: {
          ...path.params,
          lang: lang === defaultLang ? undefined : lang,
        },
        props: { project: path.props, lang },
      }))
    }),
  )
  return paths.flat()
}

const { project, lang } = Astro.props as {
  project: CollectionEntry<'project'>
  lang: Lang
}
---

<ProjectDetail project={project} lang={lang} />
